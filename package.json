  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma  || echo 'Prisma generate skipped'",
    "vercel-build": "prisma generate --schema=./prisma/schema.prisma && next build",
    "type-check": "tsc --noEmit",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
